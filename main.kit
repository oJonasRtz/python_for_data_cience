var a: num = none;
if (
	a != none,
	fn(num a){
		print(a);

		if(a & 1, print(" sou impar"))
			.else( print(" sou par") );
	}
).else(print("Nao deu certo"));

fn test1(string? str): num
{
	//contexto aterior eh a funcao, entao a funcao retorna
	if(str == none, flow.return(1));

	//Aqui o contexto eh o loop, logo ele se aplica ao loop
	foreach(str).if(it == " ", flow.break);

	//A unica excecao acaba sendo o return
	foreach(str).if(it == "\n", flow.return(2));
	// um return serve para sair da funcao atual, e eh isso q ele faz aqui

	return (0);
}


